# Copy to backend/.env and fill in. Do not commit .env.
#
# Omit DATABASE_URL to use SQLite at backend/instance/iwear_dev.db (recommended for local dev without Docker).
# For PostgreSQL (e.g. docker compose):
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/iwear_dev

SECRET_KEY=change-this
JWT_SECRET_KEY=change-this
